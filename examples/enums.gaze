// Enum definitions, pattern matching, destructuring.

enum Shape {
    Circle(Int),
    Rect(Int, Int),
}

fn area(s: Shape) -> Int {
    match s {
        Circle(r) => r * r * 3,
        Rect(w, h) => w * h,
    }
}

fn main() can Console {
    let c = Circle(5)
    let r = Rect(3, 4)
    print(area(c))
    print(area(r))
}
